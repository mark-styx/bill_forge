# =============================================================================
# BillForge Environment Configuration
# =============================================================================
# Copy this file to .env and fill in the required values.
# Required variables are marked with [REQUIRED], optional with [OPTIONAL].
# =============================================================================

# --- Core Settings -----------------------------------------------------------
ENVIRONMENT=development                         # [REQUIRED] development | staging | production
BACKEND_HOST=0.0.0.0                            # [OPTIONAL] Default: 0.0.0.0
BACKEND_PORT=8080                               # [OPTIONAL] Default: 8080
FRONTEND_URL=http://localhost:3000               # [REQUIRED] Used for CORS and email links
APP_URL=http://localhost:8080                    # [REQUIRED] Public backend URL
ALLOWED_ORIGINS=http://localhost:3000            # [REQUIRED] Comma-separated CORS origins

# --- Database ----------------------------------------------------------------
DATABASE_URL=postgres://postgres:postgres@localhost:5432/billforge  # [REQUIRED]
REDIS_URL=redis://localhost:6379                 # [REQUIRED] Session cache, job queue

# --- Authentication ----------------------------------------------------------
JWT_SECRET=change-me-to-a-random-64-char-string  # [REQUIRED] Min 32 chars
JWT_EXPIRY=3600                                  # [OPTIONAL] Token expiry in seconds (default: 1hr)
TOKEN_SECRET_KEY=change-me-too                   # [REQUIRED] For email action tokens (HMAC)

# --- Storage -----------------------------------------------------------------
STORAGE_PROVIDER=local                           # [REQUIRED] local | s3
LOCAL_STORAGE_PATH=./data/files                  # [OPTIONAL] Path when using local storage

# S3-compatible storage (required if STORAGE_PROVIDER=s3)
S3_BUCKET=                                       # [CONDITIONAL] S3 bucket name
S3_REGION=us-east-1                              # [CONDITIONAL] AWS region
S3_ENDPOINT=                                     # [OPTIONAL] Custom endpoint (MinIO, R2, etc.)
S3_KEY_PREFIX=uploads                            # [OPTIONAL] Key prefix in bucket
AWS_ACCESS_KEY_ID=                               # [CONDITIONAL] AWS credentials
AWS_SECRET_ACCESS_KEY=                           # [CONDITIONAL] AWS credentials
AWS_REGION=us-east-1                             # [CONDITIONAL] AWS region

# --- OCR ---------------------------------------------------------------------
OCR_PROVIDER=tesseract                           # [REQUIRED] tesseract | aws_textract | google_vision
TESSERACT_PATH=/usr/bin/tesseract                # [OPTIONAL] Path to tesseract binary
TESSERACT_LANG=eng                               # [OPTIONAL] OCR language

# Google Vision (required if OCR_PROVIDER=google_vision)
GOOGLE_APPLICATION_CREDENTIALS=                  # [CONDITIONAL] Path to service account JSON
GOOGLE_CLOUD_PROJECT=                            # [CONDITIONAL] GCP project ID

# --- Email -------------------------------------------------------------------
EMAIL_ENABLED=false                              # [OPTIONAL] Enable email notifications
EMAIL_PROVIDER=sendgrid                          # [OPTIONAL] sendgrid | mailgun
EMAIL_FROM=noreply@billforge.io                  # [OPTIONAL] Sender address
EMAIL_FROM_NAME=BillForge                        # [OPTIONAL] Sender name

# SendGrid (required if EMAIL_PROVIDER=sendgrid)
SENDGRID_API_KEY=                                # [CONDITIONAL]

# Mailgun (required if EMAIL_PROVIDER=mailgun)
MAILGUN_API_KEY=                                 # [CONDITIONAL]
MAILGUN_DOMAIN=                                  # [CONDITIONAL]

# Email webhooks (for approval-by-email)
EMAIL_WEBHOOK_URL=                               # [OPTIONAL] Webhook endpoint for email events
EMAIL_WEBHOOK_AUTH=                              # [OPTIONAL] Webhook auth token

# --- Accounting Integrations -------------------------------------------------
# QuickBooks Online
QUICKBOOKS_CLIENT_ID=                            # [OPTIONAL] OAuth client ID
QUICKBOOKS_CLIENT_SECRET=                        # [OPTIONAL] OAuth client secret
QUICKBOOKS_REDIRECT_URI=http://localhost:8080/api/quickbooks/callback
QUICKBOOKS_ENVIRONMENT=sandbox                   # [OPTIONAL] sandbox | production

# Xero
XERO_CLIENT_ID=                                  # [OPTIONAL] OAuth client ID
XERO_CLIENT_SECRET=                              # [OPTIONAL] OAuth client secret
XERO_REDIRECT_URI=http://localhost:8080/api/xero/callback
XERO_ENVIRONMENT=sandbox                         # [OPTIONAL] sandbox | production

# --- Notifications -----------------------------------------------------------
# Slack
SLACK_CLIENT_ID=                                 # [OPTIONAL] Slack app client ID
SLACK_CLIENT_SECRET=                             # [OPTIONAL] Slack app client secret
SLACK_REDIRECT_URI=http://localhost:8080/api/notifications/slack/callback

# Push notifications (mobile)
FCM_API_KEY=                                     # [OPTIONAL] Firebase Cloud Messaging
APNS_KEY_ID=                                     # [OPTIONAL] Apple Push Notification Service
APNS_TEAM_ID=                                    # [OPTIONAL]
APNS_BUNDLE_ID=                                  # [OPTIONAL]
APNS_PRIVATE_KEY_PATH=                           # [OPTIONAL]
APNS_ENVIRONMENT=development                     # [OPTIONAL] development | production

# --- AI / ML -----------------------------------------------------------------
OPENAI_API_KEY=                                  # [OPTIONAL] For AI-assisted categorization

# --- Worker ------------------------------------------------------------------
WORKER_MODE=inline                               # [OPTIONAL] inline | background
MAX_CONCURRENT_JOBS=4                            # [OPTIONAL] Max parallel background jobs
JOB_POLL_INTERVAL_SECS=5                         # [OPTIONAL] Job queue poll interval

# --- Rate Limiting -----------------------------------------------------------
RATE_LIMIT_RPM=60                                # [OPTIONAL] Requests per minute
RATE_LIMIT_BURST=10                              # [OPTIONAL] Burst allowance

# --- Billing (if multi-tenant billing enabled) --------------------------------
BILLING_ENABLED=false                            # [OPTIONAL]
STRIPE_API_KEY=                                  # [CONDITIONAL] Required if billing enabled
STRIPE_WEBHOOK_SECRET=                           # [CONDITIONAL]
DEFAULT_TRIAL_DAYS=14                            # [OPTIONAL]

# --- Frontend (Next.js) ------------------------------------------------------
NEXT_PUBLIC_API_URL=http://localhost:8080/api     # [REQUIRED] Backend API URL for browser
