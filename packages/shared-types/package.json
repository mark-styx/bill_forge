{
  "name": "@billforge/shared-types",
  "version": "0.0.1",
  "private": true,
  "main": "./src/index.ts",
  "types": "./src/index.ts",
  "exports": {
    ".": "./src/index.ts"
  },
  "scripts": {
    "gen:openapi": "cargo run -p billforge-api --bin export-openapi -- ./openapi.json",
    "gen:types": "pnpm gen:openapi && openapi-typescript ./openapi.json -o ./src/generated.ts && node scripts/postgen-nocheck.cjs",
    "check:types": "pnpm gen:types && git diff --exit-code openapi.json src/generated.ts",
    "test": "vitest run"
  },
  "devDependencies": {
    "openapi-typescript": "^7",
    "vitest": "^4.1.8"
  }
}
