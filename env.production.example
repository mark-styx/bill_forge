# BillForge Production Environment Variables
# Copy this file to .env.production and fill in your values

# PostgreSQL Configuration
POSTGRES_USER=billforge
POSTGRES_PASSWORD=<CHANGE_ME_SECURE_PASSWORD>

# Redis Configuration
REDIS_PASSWORD=<CHANGE_ME_REDIS_PASSWORD>

# MinIO (S3-Compatible Storage)
MINIO_ACCESS_KEY=billforge-admin
MINIO_SECRET_KEY=<CHANGE_ME_MINIO_SECRET>

# Application Secrets
JWT_SECRET=<GENERATE_32_BYTE_SECRET>

# Grafana
GRAFANA_ADMIN_USER=admin
GRAFANA_ADMIN_PASSWORD=<CHANGE_ME_GRAFANA_PASSWORD>

# CORS Allowed Origins
ALLOWED_ORIGINS=https://your-domain.com,https://app.your-domain.com

# QuickBooks Integration
QUICKBOOKS_CLIENT_ID=<YOUR_QUICKBOOKS_CLIENT_ID>
QUICKBOOKS_CLIENT_SECRET=<YOUR_QUICKBOOKS_CLIENT_SECRET>
QUICKBOOKS_REDIRECT_URI=https://api.your-domain.com/api/v1/quickbooks/callback
QUICKBOOKS_ENVIRONMENT=production
APP_URL=https://app.your-domain.com

# Monitoring
JOB_POLL_INTERVAL_SECS=5
MAX_CONCURRENT_JOBS=20

# Optional: External Services
# SENDGRID_API_KEY=<YOUR_SENDGRID_KEY>
# SENTRY_DSN=<YOUR_SENTRY_DSN>
