  "query": "\n        SELECT id, vendor_name, invoice_number, total_amount_cents, currency, due_date, processing_status\n        FROM invoices\n        WHERE tenant_id = $1\n          AND ($2::text IS NULL OR processing_status = $2)\n        ORDER BY created_at DESC\n        LIMIT $3 OFFSET $4\n        ",
