  "query": "\n        SELECT id, vendor_name, invoice_number, total_amount_cents, currency\n        FROM invoices\n        WHERE tenant_id = $1\n          AND (vendor_name ILIKE $2 OR invoice_number ILIKE $2)\n        ORDER BY created_at DESC\n        LIMIT $3\n        ",
