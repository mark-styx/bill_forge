{
  "db_name": "PostgreSQL",
  "query": "\n        SELECT\n            ar.id,\n            ar.invoice_id,\n            i.vendor_name,\n            i.invoice_number,\n            i.total_amount_cents,\n            i.currency,\n            i.due_date,\n            i.processing_status,\n            ar.created_at\n        FROM approval_requests ar\n        JOIN invoices i ON ar.invoice_id = i.id\n        WHERE ar.tenant_id = $1\n          AND ar.requested_from->>'user_id' = $2\n          AND ar.status = 'pending'\n        ORDER BY ar.created_at DESC\n        LIMIT 50\n        ",
