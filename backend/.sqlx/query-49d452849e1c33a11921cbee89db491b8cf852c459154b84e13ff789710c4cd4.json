  "query": "\n        SELECT id, vendor_name, invoice_number, total_amount_cents, currency, due_date, processing_status, modified_at\n        FROM invoices\n        WHERE tenant_id = $1\n          AND modified_at > $2\n        ORDER BY modified_at DESC\n        LIMIT $3\n        ",
