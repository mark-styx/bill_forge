# BillForge Environment Configuration
# Copy this file to .env and fill in your values

# =============================================================================
# Application Environment
# =============================================================================
# Options: development, staging, production
ENVIRONMENT=development
NODE_ENV=development
LOG_LEVEL=debug
RUST_LOG=debug,billforge_api=debug

# =============================================================================
# Backend Server
# =============================================================================
BACKEND_HOST=127.0.0.1
BACKEND_PORT=8080
FRONTEND_URL=http://localhost:3000

# Additional allowed CORS origins (comma-separated)
# In production, only include trusted domains
ALLOWED_ORIGINS=http://localhost:3000,http://localhost:3001

# =============================================================================
# Database Configuration
# =============================================================================
# SQLite for metadata and auth
DATABASE_URL=sqlite://./data/billforge.db

# Path where tenant DuckDB files are stored
TENANT_DB_PATH=./data/tenants

# =============================================================================
# Authentication
# =============================================================================
JWT_SECRET=change-this-to-a-secure-random-string-in-production
JWT_EXPIRY=24h
REFRESH_TOKEN_EXPIRY=7d

# Password hashing (Argon2)
ARGON_MEMORY_COST=65536
ARGON_TIME_COST=3
ARGON_PARALLELISM=4

# =============================================================================
# OCR Configuration
# =============================================================================
# Options: tesseract, aws_textract, google_vision
OCR_PROVIDER=tesseract

# Tesseract (local)
TESSERACT_PATH=/usr/local/bin/tesseract
TESSERACT_LANG=eng

# AWS Textract
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_REGION=us-east-1

# Google Cloud Vision
GOOGLE_APPLICATION_CREDENTIALS=

# =============================================================================
# File Storage
# =============================================================================
# Options: local, s3
STORAGE_PROVIDER=local

# Local storage path
LOCAL_STORAGE_PATH=./data/files

# S3 Configuration (also works with MinIO, DigitalOcean Spaces, etc.)
S3_BUCKET=billforge-files
S3_REGION=us-east-1
S3_ENDPOINT=  # Leave empty for AWS S3, set for S3-compatible services
S3_ACCESS_KEY=
S3_SECRET_KEY=

# =============================================================================
# Email Configuration (for notifications)
# =============================================================================
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASSWORD=
SMTP_FROM=noreply@billforge.app

# =============================================================================
# Feature Flags
# =============================================================================
ENABLE_SANDBOX_MODE=true
ENABLE_API_DOCS=true
ENABLE_METRICS=true

# =============================================================================
# Rate Limiting
# =============================================================================
# Requests per minute per IP address
RATE_LIMIT_RPM=100
# Burst size for rate limiting
RATE_LIMIT_BURST=20

# =============================================================================
# Sandbox Mode (Development)
# =============================================================================
SANDBOX_TENANT_ID=sandbox-tenant-001
SANDBOX_ADMIN_EMAIL=admin@sandbox.local
SANDBOX_ADMIN_PASSWORD=sandbox123
