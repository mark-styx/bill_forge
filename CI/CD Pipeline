name: Vendor Matching System Deployment

on:
  push:
    branches:
      - main

jobs:
  build-and-test:
    runs-on: ubuntu-latest

    steps:
    - name: Checkout code
      uses: actions/checkout@v2

    - name: Set up Node.js
      uses: actions/setup-node@v2
      with:
        node-version: '14'

    - name: Install dependencies
      run: npm install

    - name: Run tests
      run: npm test

  deploy-ecs:
    needs: build-and-test
    runs-on: ubuntu-latest

    steps:
    - name: Checkout code
      uses: actions/checkout@v2

    - name: Set up Node.js
      uses: actions/setup-node@v2
      with:
        node-version: '14'

    - name: Install dependencies
      run: npm install

    - name: Build Docker image
      run: docker build -t vendor-matching-app .

    - name: Push Docker image to AWS ECR
      run: |
        aws ecr get-login-password --region ${{ params.region }} | docker login --username AWS --password-stdin ${{ params.ecr_repository_url }}
        docker tag vendor-matching-app ${{ params.ecr_repository_url }}/vendor-matching-app:${{ github.sha }}
        docker push ${{ params.ecr_repository_url }}/vendor-matching-app:${{ github.sha }}

    - name: Deploy to ECS
      uses: AWS-CDK/infra-actions@v2
      with:
        command: deploy --app ./
        stack-name: vendor-matching-app-stack
        context-values: "app.region=${{ params.region }} app.ecr_repository_url=${{ params.ecr_repository_url }}"
        aws-access-key-id: ${{ secrets.AWS_ACCESS_KEY_ID }}
        aws-secret-access-key: ${{ secrets.AWS_SECRET_ACCESS_KEY }}

  deploy-lambda:
    needs: build-and-test
    runs-on: ubuntu-latest

    steps:
    - name: Checkout code
      uses: actions/checkout@v2

    - name: Set up Node.js
      uses: actions/setup-node@v2
      with:
        node-version: '14'

    - name: Install dependencies
      run: npm install

    - name: Build Lambda package
      run: zip -r vendor-matching-lambda.zip .

    - name: Deploy Lambda function
      uses: appleboy/scp-action@master
      with:
        host: ${{ secrets.AWS_LAMBDA_HOST }}
        username: ${{ secrets.AWS_LAMBDA_USERNAME }}
        password: ${{ secrets.AWS_LAMBDA_PASSWORD }}
        source: vendor-matching-lambda.zip
        target: /tmp/vendor-matching-lambda.zip

    - name: Update Lambda function code
      uses: appleboy/ssh-action@master
      with:
        host: ${{ secrets.AWS_LAMBDA_HOST }}
        username: ${{ secrets.AWS_LAMBDA_USERNAME }}
        password: ${{ secrets.AWS_LAMBDA_PASSWORD }}
        script: |
          aws lambda update-function-code \
            --function-name vendor-matching-lambda \
            --zip-file fileb:///tmp/vendor-matching-lambda.zip