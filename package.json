{
  "name": "billforge",
  "version": "0.1.0",
  "private": true,
  "description": "Modular SaaS platform for Accounts Payable teams",
  "scripts": {
    "dev": "pnpm --filter @billforge/web dev",
    "build": "pnpm --filter @billforge/web build",
    "start": "pnpm --filter @billforge/web start",
    "lint": "pnpm -r lint",
    "typecheck": "pnpm -r typecheck",
    "test": "pnpm -r test",
    "db:migrate": "cd backend && cargo run --bin migrate",
    "backend:dev": "cd backend && cargo watch -x run",
    "backend:build": "cd backend && cargo build --release",
    "sandbox:start": "docker-compose -f docker/docker-compose.sandbox.yml up -d && pnpm sandbox:seed && pnpm dev",
    "sandbox:seed": "cd sandbox && pnpm seed",
    "sandbox:reset": "docker-compose -f docker/docker-compose.sandbox.yml down -v && pnpm sandbox:start",
    "clean": "rm -rf node_modules apps/*/node_modules packages/*/node_modules backend/target"
  },
  "devDependencies": {
    "@types/node": "^20.10.0",
    "eslint": "^8.55.0",
    "playwright": "^1.58.2",
    "prettier": "^3.1.0",
    "ts-jest": "^29.4.9",
    "typescript": "^5.3.0"
  },
  "pnpm": {
    "overrides": {
      "tar": ">=7.5.11",
      "picomatch": ">=4.0.4",
      "lodash": ">=4.18.0",
      "@xmldom/xmldom": ">=0.8.12",
      "esbuild": ">=0.25.0",
      "brace-expansion": ">=2.0.3"
    }
  },
  "engines": {
    "node": ">=20.0.0",
    "pnpm": ">=9.0.0"
  },
  "packageManager": "pnpm@9.15.4"
}
